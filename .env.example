# =============================================
# AI 語音會議助理 - 環境變數設定範例
# 複製此檔案為 .env 並填入你的 API Key
# =============================================

# ── Google Gemini AI ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# 雙模型架構：音訊轉逐字稿使用轉錄模型；完整逐字稿產生摘要/決議/待辦使用摘要模型。
TRANSCRIPTION_MODEL=gemini-3.1-flash-lite
SUMMARY_MODEL=gemma-4-31b-it
SUMMARY_FALLBACK_MODEL=gemini-3.1-flash-lite

# ── LINE Bot (Phase 3) ────────────────────────────────
# 取得方式：LINE Developers Console → 您的 Channel → Basic settings
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# 取得方式：LINE Developers Console → 您的 Channel → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ── 本機後端安全設定 ──────────────────────────────────
# /line-webhook 保持公開給 LINE 平台呼叫，並由 LINE 簽章驗證。
# 同 Wi-Fi / 信任本機網段預設可直接開 Web；ngrok 等公開入口需使用 APP_API_KEY。
APP_API_KEY=change_me_to_a_long_random_value

# 上傳檔案大小上限，單位 MB。
MAX_UPLOAD_MB=500

# 允許的瀏覽器來源，以逗號分隔。
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001

# 是否允許同 Wi-Fi / 信任本機網段直接開啟 Web 介面。
# 預設 1；若改為 0，手機 / 平板網址會需要 api_key。
MEETING_ASSISTANT_TRUST_LOCAL_NETWORK=1

# ── ngrok / LINE Webhook 開發 tunnel ─────────────────
# 一鍵啟動預設會嘗試啟動 ngrok；若要停用請設為 0。
MEETING_ASSISTANT_NGROK=1

# 若使用 ngrok reserved/static domain，填入不含 /line-webhook 的公開 URL。
# 留空時，一鍵啟動會嘗試從 LINE Console 既有 Webhook URL 自動推回公開 URL。
MEETING_ASSISTANT_NGROK_URL=

# ngrok 本機狀態 API；前端維運面板會用後端 /metrics 顯示 tunnel 狀態。
MEETING_ASSISTANT_NGROK_API_URL=http://127.0.0.1:4040/api/tunnels

# ── 本機資料夾路徑 ───────────────────────────────────
DB_PATH=./meetings.db
MEETING_TEMP_DIR=./temp
MEETING_OUTPUT_DIR=./output
MEETING_ATTACHMENT_DIR=./output/attachments
MEETING_BACKUP_DIR=./backups

# Word 匯出範本路徑。此檔案含公司表單樣式時請保留在本機，不提交到 Git。
MEETING_DOCX_TEMPLATE_PATH=./4-QA-005 V01 會議紀錄.docx
